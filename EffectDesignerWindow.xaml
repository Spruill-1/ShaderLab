<Window
    x:Class="ShaderLab.EffectDesignerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Effect Designer">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Scrollable settings (name, inputs, params, compute) -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="8">
                <!-- Name and Type -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Effect Name:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="EffectNameBox" Grid.Column="1" PlaceholderText="My Custom Effect" />
                    <TextBlock Text="Type:" Grid.Column="2" VerticalAlignment="Center" Margin="16,0,8,0" />
                    <ComboBox x:Name="ShaderTypeSelector" Grid.Column="3" MinWidth="180">
                        <x:String>Pixel Shader</x:String>
                        <x:String>Compute Shader</x:String>
                        <x:String>D3D11 Compute Shader</x:String>
                    </ComboBox>
                </Grid>

                <!-- Inputs -->
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Inputs" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="AddInputButton" Grid.Column="1" Content="+ Add Input" />
                    </Grid>
                    <StackPanel x:Name="InputsPanel" Spacing="4" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Parameters -->
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Parameters" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="AddParamButton" Grid.Column="1" Content="+ Add Parameter" />
                    </Grid>
                    <StackPanel x:Name="ParamsPanel" Spacing="4" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Compute Settings + Analysis Outputs -->
                <StackPanel x:Name="ComputeSettingsPanel" Visibility="Collapsed" Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Thread Group:" VerticalAlignment="Center" />
                        <NumberBox x:Name="ThreadGroupX" Value="8" Minimum="1" Maximum="1024"
                                   SpinButtonPlacementMode="Compact" Width="80" />
                        <TextBlock Text="×" VerticalAlignment="Center" />
                        <NumberBox x:Name="ThreadGroupY" Value="8" Minimum="1" Maximum="1024"
                                   SpinButtonPlacementMode="Compact" Width="80" />
                        <TextBlock Text="×" VerticalAlignment="Center" />
                        <NumberBox x:Name="ThreadGroupZ" Value="1" Minimum="1" Maximum="64"
                                   SpinButtonPlacementMode="Compact" Width="80" />
                        <AppBarSeparator />
                        <TextBlock Text="Output:" VerticalAlignment="Center" />
                        <ComboBox x:Name="OutputTypeSelector" MinWidth="100">
                            <x:String>None</x:String>
                            <x:String>Histogram</x:String>
                            <x:String>Float Buffer</x:String>
                            <x:String>Typed Analysis</x:String>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="AnalysisFieldsSection" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Analysis Output Fields" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button x:Name="AddAnalysisFieldButton" Grid.Column="1"
                                    Content="+ Add Field" />
                        </Grid>
                        <StackPanel x:Name="AnalysisFieldsPanel" Spacing="4" Margin="0,4,0,0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Row 1: Action buttons (always visible between settings and editor) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button x:Name="GenerateScaffoldButton" Content="Generate Scaffold"
                    Style="{StaticResource AccentButtonStyle}" />
            <Button x:Name="CompileButton" Content="Compile (Ctrl+Enter)" />
            <Button x:Name="FormatButton" Content="Format" />
            <Button x:Name="AddToGraphButton" Content="Add to Graph" IsEnabled="False" />
            <Button x:Name="UpdateInGraphButton" Content="Update in Graph" IsEnabled="False"
                    Visibility="Collapsed" />
        </StackPanel>

        <!-- Row 2: HLSL Editor -->
        <TextBox x:Name="HlslEditorBox" Grid.Row="2"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Cascadia Mono, Consolas, Courier New"
                 FontSize="13"
                 PlaceholderText="// Click 'Generate Scaffold' to create HLSL boilerplate..."
                 IsSpellCheckEnabled="False"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />

        <!-- Row 3: Status bar -->
        <Grid Grid.Row="3" Padding="4"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              CornerRadius="4">
            <TextBlock x:Name="CompileStatusText"
                       Text="Ready"
                       FontFamily="Cascadia Mono, Consolas, Courier New"
                       FontSize="12"
                       TextWrapping="Wrap"
                       MaxLines="5" />
        </Grid>
    </Grid>
</Window>
